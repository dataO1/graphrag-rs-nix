{
  "name": "pi-memory",
  "version": "1.0.0",
  "private": true,
  "description": "Long-term memory extension for pi coding agent — recall, remember, forget, catalog, status, log_action, log_decision",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "bash test/integration/pi-live-smoke.sh",
    "test:all": "vitest run && bash test/integration/pi-live-smoke.sh"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  }
}
